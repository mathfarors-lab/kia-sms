APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# KIA School — production settings
APP_TIMEZONE=Asia/Phnom_Penh

# SMS — drivers: log (default, safe) | plasgate (Cambodian gateway) | twilio
# Plasgate: register at plasgate.com, then set the three values below and
# SMS_DRIVER=plasgate. Numbers are auto-normalized to 855-format.
SMS_DRIVER=log
PLASGATE_BASE_URL=https://cloudapi.plasgate.com/rest/send
PLASGATE_PRIVATE_KEY=
PLASGATE_SECRET=
PLASGATE_SENDER="KIA School"
# Twilio (alternative; requires composer require twilio/sdk)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Bakong KHQR — Pull/Polling Model (default)
# ⚠️  Production server MUST have a Cambodia-based IP — NBC blocks outside Cambodia.
BAKONG_FAKE_MODE=true               # set false in production
BAKONG_API_BASE_URL=                # e.g. https://api-bakong.nbc.gov.kh
BAKONG_MERCHANT_EMAIL=              # registered merchant email for token login
BAKONG_MERCHANT_ID=                 # merchant wallet ID, e.g. 855012345678@aba
BAKONG_MERCHANT_NAME="KIA School"
BAKONG_MERCHANT_CITY="Phnom Penh"
BAKONG_QR_TTL_MINUTES=10           # KHQR window (default 10 min per NBC spec)

# Bakong Push Webhook (bank/PSP integration — disable when using polling above)
BAKONG_DISABLE_WEBHOOK=true        # set false ONLY if using a real PUSH webhook
BAKONG_WEBHOOK_SECRET=
BAKONG_SIGNATURE_HEADER=X-Bakong-Signature
BAKONG_SIGNATURE_ALGO=sha256

# Backup (spatie/laravel-backup) — nightly at 02:00 via the scheduler.
# BACKUP_DISK_ROOT must live OFF the app's drive; in production replace the
# "backups" disk with real off-server storage (S3/Backblaze). Restore steps:
# see BACKUP_RESTORE.md.
BACKUP_DISK_ROOT="C:/Backups/kia-sms"
MYSQL_DUMP_BINARY_PATH="C:/xampp/mysql/bin"
BACKUP_NOTIFICATION_EMAIL=admin@kia.edu.kh
# Optional: encrypt archives (recommended in production, REQUIRED if you ever
# include .env in the backup). Losing this password = losing the backups.
BACKUP_ARCHIVE_PASSWORD=
